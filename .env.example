# Scriptonyapp Environment Variables
# Copy this file to .env and fill in your values
# 
# All values can be customized for different domains/environments

# ============================================
# DOMAIN CONFIGURATION
# ============================================
# Your domain (used for SSL, CORS, etc.)
DOMAIN=scriptony.raccoova.com

# Ports (can be changed if needed)
FRONTEND_PORT=8080
BACKEND_PORT=3000

# Backend service name (for Docker internal communication)
BACKEND_HOST=scriptony-api

# ============================================
# FRONTEND
# ============================================
# Full API URL that the frontend will use
VITE_API_URL=http://${BACKEND_HOST}:${BACKEND_PORT}

# ============================================
# BACKEND API
# ============================================
NODE_ENV=production
PORT=3000

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/scriptony

# ============================================
# JWT Authentication
# ============================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here

# ============================================
# GOOGLE OAUTH - Auth Service
# ============================================
GOOGLE_AUTH_CLIENT_ID=your-google-auth-client-id.apps.googleusercontent.com
GOOGLE_AUTH_CLIENT_SECRET=your-google-auth-client-secret

# ============================================
# GOOGLE OAUTH - Drive Service
# ============================================
GOOGLE_DRIVE_CLIENT_ID=your-google-drive-client-id.apps.googleusercontent.com
GOOGLE_DRIVE_CLIENT_SECRET=your-google-drive-client-secret

# ============================================
# STORAGE (MinIO / S3)
# ============================================
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=scriptony-uploads
MINIO_USE_SSL=false

# ============================================
# OPTIONAL: SSL / Let's Encrypt
# ============================================
# Email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@raccoova.com

# ============================================
# OPTIONAL: Sentry Error Tracking
# ============================================
# SENTRY_DSN=your-sentry-dsn

# ============================================
# OPTIONAL: Telegram Notifications
# ============================================
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id

# ============================================
# OPTIONAL: GitHub Actions SSH Deployment
# ============================================
# SSH_HOST=your-server-ip
# SSH_USER=ubuntu
# SSH_PRIVATE_KEY_PATH=~/.ssh/id_rsa

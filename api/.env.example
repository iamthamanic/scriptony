# Scriptony API Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ============================================
# CORS CONFIGURATION
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:8080,http://localhost:3000,https://scriptony.raccoova.com

# ============================================
# DATABASE (PostgreSQL)
# ============================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/scriptony

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ============================================
# GOOGLE OAUTH - Auth Service
# ============================================
GOOGLE_AUTH_CLIENT_ID=your-google-auth-client-id.apps.googleusercontent.com
GOOGLE_AUTH_CLIENT_SECRET=your-google-auth-client-secret

# ============================================
# GOOGLE OAUTH - Drive Service
# ============================================
GOOGLE_DRIVE_CLIENT_ID=your-google-drive-client-id.apps.googleusercontent.com
GOOGLE_DRIVE_CLIENT_SECRET=your-google-drive-client-secret

# ============================================
# STORAGE (MinIO / S3)
# ============================================
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=scriptony-uploads

# ============================================
# OPTIONAL: Sentry Error Tracking
# ============================================
# SENTRY_DSN=your-sentry-dsn

# ============================================
# OPTIONAL: Admin Configuration
# ============================================
# ADMIN_EMAIL=admin@raccoova.com

{
  "name": "scriptony-api",
  "version": "1.0.0",
  "description": "Fastify API backend for Scriptonyapp",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
